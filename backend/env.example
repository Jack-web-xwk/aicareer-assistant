# AI Career Assistant - Environment Variables
# Rename this file to .env and fill in your values

# OpenAI API Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# Database Configuration (must use aiosqlite for async support)
DATABASE_URL=sqlite+aiosqlite:///./data/career_assistant.db

# Application Settings
APP_NAME=AI Career Assistant
APP_VERSION=1.0.0
DEBUG=true

# CORS Settings (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# File Upload Settings
MAX_UPLOAD_SIZE_MB=10
UPLOAD_DIR=./uploads

# Audio Processing Settings
AUDIO_FORMAT=mp3
TTS_VOICE=alloy

# Interview Settings
MAX_INTERVIEW_QUESTIONS=5
