# AI Career Assistant - Environment Variables
# Rename this file to .env and fill in your values

# ============================================
# LLM Provider Configuration (通用配置)
# ============================================
# 选择默认使用的 LLM 提供商
# 可选值: openai, deepseek, zhipu, ollama, anthropic, qwen, bailian
LLM_PROVIDER=bailian

# 指定模型名称 (留空则使用各提供商默认模型)
LLM_MODEL=qwen-plus
LLM_REQUEST_TIMEOUT=120

# Resume study QA (POST /resume/{id}/study-qa)
RESUME_STUDY_QA_MAX_ITEMS=8
# Empty model = LLM_MODEL; with bailian: qwen-plus, qwen-turbo, qwen-max, deepseek-v3, etc.
RESUME_STUDY_QA_MODEL=
# Empty = LLM_PROVIDER; set bailian to use 百炼 regardless of global provider
RESUME_STUDY_QA_PROVIDER=

# ============================================
# OpenAI Configuration
# ============================================
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
# 可选模型: gpt-4o, gpt-4o-mini, gpt-4-turbo, gpt-4, gpt-3.5-turbo, o1, o1-mini

# ============================================
# DeepSeek Configuration (推荐)
# ============================================
# 官网: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_MODEL=deepseek-chat
# 可选模型:
# - deepseek-chat: DeepSeek-V3 通用对话 (性价比高)
# - deepseek-coder: 代码专用
# - deepseek-reasoner: R1 推理模型 (复杂问题推荐)

# ============================================
# 智谱 GLM Configuration
# ============================================
# 官网: https://open.bigmodel.cn/
ZHIPU_API_KEY=your-zhipu-api-key-here
ZHIPU_MODEL=glm-4-flash
# 可选模型: glm-4-plus, glm-4, glm-4-air, glm-4-airx, glm-4-long, glm-4-flash, codegeex-4

# ============================================
# Ollama Configuration (本地模型)
# ============================================
# 安装: https://ollama.com/
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=ollama
OLLAMA_MODEL=llama3.2
# 可选模型: llama3.2, llama3.1, qwen2.5, qwen2.5-coder, deepseek-coder-v2, mistral, phi3

# ============================================
# Anthropic Claude Configuration
# ============================================
# 官网: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
# 可选模型: claude-3-5-sonnet-20241022, claude-3-5-haiku-20241022, claude-3-opus-20240229

# ============================================
# 通义千问 Qwen Configuration
# ============================================
# 官网: https://dashscope.console.aliyun.com/
QWEN_API_KEY=sk-your-qwen-api-key-here
QWEN_MODEL=qwen-turbo
# 可选模型: qwen-turbo, qwen-plus, qwen-max, qwen-long, qwen-coder-turbo

# ============================================
# 阿里百炼 Bailian Configuration
# ============================================
# 官网: https://bailian.console.aliyun.com/
BAILIAN_API_KEY=sk-your-bailian-api-key-here
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
BAILIAN_MODEL=qwen-plus
# 可选模型: qwen-turbo, qwen-plus, qwen-max, qwen-long, qwen-coder-turbo

# ============================================
# Database Configuration
# ============================================
# 开发环境 (SQLite):
DATABASE_URL=sqlite+aiosqlite:///./data/career_assistant.db
# 生产环境 (PostgreSQL):
# DATABASE_URL=postgresql+asyncpg://careers:careers123@localhost:5432/aicareer

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT Secret (留空自动生成)
JWT_SECRET_KEY=

# ============================================
# Application Settings
# ============================================
APP_NAME=AI Career Assistant
APP_VERSION=1.0.0
DEBUG=true

# ============================================
# CORS Settings
# ============================================
# Comma-separated origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================================
# File Upload Settings
# ============================================
MAX_UPLOAD_SIZE_MB=10
UPLOAD_DIR=./uploads

# ============================================
# Audio Processing Settings
# ============================================
# Note: Audio features (Whisper/TTS) require OpenAI API Key
AUDIO_FORMAT=mp3
TTS_VOICE=alloy
# TTS voices: alloy, echo, fable, onyx, nova, shimmer

# ============================================
# Interview Settings
# ============================================
MAX_INTERVIEW_QUESTIONS=5

# ============================================
# Job Search (multi-source list / crawler)
# ============================================
# 每 IP 每分钟允许的职位搜索请求次数（滑动窗口）
JOB_SEARCH_RATE_LIMIT_PER_MINUTE=10
# 进程内缓存 TTL（秒），相同查询参数命中则跳过后端外呼
JOB_SEARCH_CACHE_TTL_SECONDS=300

# 岗位链接爬取：直连失败或解析为空时，用 Jina Reader 兜底（默认开启）
# JOB_SCRAPE_JINA_READER_FALLBACK=true
# JINA_READER_BASE_URL=https://r.jina.ai
# JINA_API_KEY=
# 第三层：Scrapling Fetcher（需 pip install "scrapling[fetchers]"），默认关闭
# JOB_SCRAPE_SCRAPLING_FALLBACK=false
# JOB_SCRAPE_SCRAPLING_VERIFY_SSL=true

# ============================================
# 截图识别岗位（多模态，可选）
# ============================================
# 单张图片最大体积（MB）
JOB_SCREENSHOT_MAX_IMAGE_MB=8
# 留空则按顺序自动尝试：百炼或通义(DashScope 多模型链) → OpenAI(gpt-4o-mini→gpt-4o) → 智谱 glm-4v→glm-4v-plus；失败自动换下一项
# JOB_SCREENSHOT_VISION_PROVIDER=openai
# JOB_SCREENSHOT_VISION_MODEL=gpt-4o-mini
# 逗号分隔，追加在 DashScope 默认链之后（可选）
# JOB_SCREENSHOT_VISION_MODEL_FALLBACKS=

# ============================================
# Boss 直聘详情页抓取（可选）
# ============================================
# 机房 IP 常被接口拒绝（WAPI code=35）。推荐：F12 → Network → 选中 zhipin.com 请求 →
# Request Headers 里复制「Cookie:」后的整段（不要自己挑单个 cookie 名）。
# 一行，勿提交到 Git。
# BOSS_ZHIPIN_EXTRA_COOKIES=